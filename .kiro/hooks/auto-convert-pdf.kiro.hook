{
  "enabled": true,
  "name": "Auto Convert to PDF on Save",
  "description": "Automatically converts markdown files to PDF format whenever you save a .md file",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "docs/*.md"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "./file_conversion_tool/scripts/convert-with-pagebreak.sh \"${FILE}\""
  }
}